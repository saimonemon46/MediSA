# MediAI .gitignore

# Environment
.env
*.env.local

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/

# Vector store (regenerated from CSVs)
vector_store/*.faiss
vector_store/*.pkl
vector_store/*.index

# Uploads (user data — never commit)
backend_php/uploads/*
!backend_php/uploads/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Node (if added later)
node_modules/
npm-debug.log
