# MediAI — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ---- Groq API ----
GROQ_API_KEY=your_groq_api_key_here

# ---- Optional symptom image analysis ----
# Gemini Flash/Flash-Lite can analyze uploaded rash/cut/wound photos as supportive triage context.
# Leave blank to use the local low-confidence fallback.
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash-lite

# ---- FastAPI service ----
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8000
AI_SERVICE_RELOAD=true

# ---- PHP / MySQL ----
DB_HOST=localhost
DB_NAME=mediai_db
DB_USER=root
DB_PASS=your_mysql_password_here

# ---- File upload ----
MAX_UPLOAD_MB=10
UPLOAD_DIR=backend_php/uploads

# ---- Security ----
JWT_SECRET=change_this_to_a_random_secret_string_min_32_chars
SESSION_LIFETIME=86400
